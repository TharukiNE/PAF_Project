# Copy to ".env" in this folder (same directory as pom.xml) before running.
# Keys with non-empty values override application.yml via JVM system properties.
# Windows: save ".env" as UTF-8 without BOM. PowerShell Set-Content -Encoding UTF8 adds a
# BOM and breaks dotenv (Malformed entry). Use VS Code "UTF-8" (not "UTF-8 with BOM").

MONGODB_URI=
CORS_ORIGINS=
ADMIN_EMAILS=
UPLOAD_DIR=
FRONTEND_URL=

# ── Google OAuth2 ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application type)
# 3. Add Authorised JavaScript origins:  http://localhost:5173
# 4. Add Authorised redirect URIs:       http://localhost:5173/login/oauth2/code/google
# 5. Copy the Client ID and Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave this unchanged for local dev (Vite proxy forwards the callback to the backend).
GOOGLE_REDIRECT_URI=http://localhost:5173/login/oauth2/code/google

# ── JWT (login / register / API Bearer tokens) ─────────────────────────────────
# Minimum 32 characters. Override in production!
JWT_SECRET=
JWT_EXPIRATION_SECONDS=86400
